<Window x:Class="TuneFlow.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TuneFlow.UI"
        Title="TuneFlow Pro — Музыкальная система" 
        Height="850" Width="1350" 
        Background="#080808" WindowStartupLocation="CenterScreen"
        Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:PlaylistColorConverter x:Key="PlaylistConverter"/>

        <!-- СТИЛЬ ТАБЛИЦЫ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#8E8E93"/>
                        <Setter Property="Padding" Value="10,15"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ СТРОКИ С ПОДСВЕТКОЙ ПЛЕЙЛИСТА -->
        <Style x:Key="TrackRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource PlaylistConverter}">
                        <Binding Path="Id"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="CurrentLikedIds"/>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛЬ БОКОВОГО МЕНЮ (Имя: SideNavBtn) -->
        <Style x:Key="SideNavBtn" TargetType="RadioButton">
            <Setter Property="Height" Value="55"/>
            <Setter Property="Foreground" Value="#B3B3B3"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bdr" Background="Transparent" Padding="30,0" BorderThickness="5,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bdr" Property="BorderBrush" Value="#1DB954"/>
                                <Setter TargetName="Bdr" Property="Background" Value="#181818"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ КРУГЛОЙ КНОПКИ ДЛЯ ТАБЛИЦЫ -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- БОКОВАЯ ПАНЕЛЬ -->
        <Border Grid.Column="0" Background="#000000">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="TUNEFLOW" Foreground="#1DB954" FontSize="28" FontWeight="Black" Margin="30,0,0,45"/>

                <RadioButton x:Name="TabLib" Content="Библиотека" IsChecked="True" Style="{StaticResource SideNavBtn}" Checked="Tab_Changed"/>
                <RadioButton x:Name="TabPlay" Content="Мой плейлист" Style="{StaticResource SideNavBtn}" Checked="Tab_Changed"/>
                <RadioButton x:Name="TabRecs" Content="Рекомендации" Style="{StaticResource SideNavBtn}" Checked="Tab_Changed"/>
                <RadioButton x:Name="TabStats" Content="Аналитика" Style="{StaticResource SideNavBtn}" Checked="Tab_Changed"/>
                <RadioButton x:Name="TabInfo" Content="Справка" Style="{StaticResource SideNavBtn}" Checked="Tab_Changed"/>
            </StackPanel>
        </Border>

        <!-- ОСНОВНАЯ ОБЛАСТЬ -->
        <Grid Grid.Column="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ПОИСК -->
            <Grid Grid.Row="0" Margin="0,0,0,40">
                <Border Background="#242424" CornerRadius="22">
                    <Grid>
                        <TextBox x:Name="SearchTitleBox" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="16" VerticalContentAlignment="Center" Height="45" Margin="20,0,140,0" CaretBrush="White"/>
                        <Button Content="ПОИСК" HorizontalAlignment="Right" Width="120" Background="#1DB954" Click="Search_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- КОНТЕНТ (Переключаемые экраны) -->
            <Grid Grid.Row="1">

                <!-- 1. БИБЛИОТЕКА -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabLib, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ComboBox x:Name="SortByCombo" Width="180" Height="32" SelectionChanged="Sort_Changed" Background="#282828" Foreground="Black"/>
                        <CheckBox x:Name="ReverseSortCheck" Content="Реверсивный" Foreground="Gray" VerticalAlignment="Center" Margin="30,0" Click="Sort_Changed"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="TracksDataGrid" AutoGenerateColumns="False" RowStyle="{StaticResource TrackRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="АРТИСТ" Binding="{Binding Artist}" Width="*"/>
                            <DataGridTextColumn Header="НАЗВАНИЕ" Binding="{Binding Title}" Width="1.5*"/>
                            <DataGridTextColumn Header="ЖАНР" Binding="{Binding Genre}" Width="100"/>
                            <DataGridTextColumn Header="ГОД" Binding="{Binding Year}" Width="60"/>
                            <DataGridTextColumn Header="★" Binding="{Binding Rating}" Width="50"/>
                            <DataGridTemplateColumn Header="ОПЦИИ" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="❤" Background="#FF2D55" Style="{StaticResource IconBtn}" Margin="2" Click="LikeTrack_Click" Tag="{Binding Id}" Foreground="White"/>
                                            <Button Content="🔍" Background="#5856D6" Style="{StaticResource IconBtn}" Margin="2" Click="FindSimilar_Click" Tag="{Binding Id}" Foreground="White" ToolTip="Найти похожие"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- 2. ПЛЕЙЛИСТ -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabPlay, Converter={StaticResource BoolToVis}}">
                    <DataGrid x:Name="PlaylistDataGrid" AutoGenerateColumns="False" RowStyle="{StaticResource TrackRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="АРТИСТ" Binding="{Binding Artist}" Width="*"/>
                            <DataGridTextColumn Header="НАЗВАНИЕ" Binding="{Binding Title}" Width="1.5*"/>
                            <DataGridTextColumn Header="ЖАНР" Binding="{Binding Genre}" Width="120"/>
                            <DataGridTemplateColumn Header="УДАЛИТЬ" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Background="#444444" Style="{StaticResource IconBtn}" Click="RemoveFromPlaylist_Click" Tag="{Binding Id}" Foreground="White"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- 3. РЕКОМЕНДАЦИИ -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabRecs, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#121212" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="ПОИСК ПО СВЯЗЯМ (BFS)" Foreground="#1DB954" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="Люди со схожими вкусами также слушают:" Foreground="#B3B3B3" Margin="0,0,0,15"/>
                            <DataGrid x:Name="BfsRecsGrid" AutoGenerateColumns="False" IsReadOnly="True" RowStyle="{StaticResource TrackRowStyle}" Height="500">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="АРТИСТ" Binding="{Binding Artist}" Width="*"/>
                                    <DataGridTextColumn Header="ТРЕК" Binding="{Binding Title}" Width="1.5*"/>
                                    <DataGridTemplateColumn Header="ДОБАВИТЬ" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="❤" Background="#FF2D55" Style="{StaticResource IconBtn}" Click="LikeTrack_Click" Tag="{Binding Id}" Foreground="White" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#121212" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="КОЛЛАБОРАЦИЯ (ЖАККАР)" Foreground="#1DB954" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="На основе матрицы пересечения интересов:" Foreground="#B3B3B3" Margin="0,0,0,15"/>
                            <DataGrid x:Name="CollabRecsGrid" AutoGenerateColumns="False" IsReadOnly="True" RowStyle="{StaticResource TrackRowStyle}" Height="500">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="АРТИСТ" Binding="{Binding Artist}" Width="*"/>
                                    <DataGridTextColumn Header="ТРЕК" Binding="{Binding Title}" Width="1.5*"/>
                                    <DataGridTemplateColumn Header="ДОБАВИТЬ" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="❤" Background="#FF2D55" Style="{StaticResource IconBtn}" Click="LikeTrack_Click" Tag="{Binding Id}" Foreground="White"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 4. СТАТИСТИКА -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabStats, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#121212" CornerRadius="20" Padding="30">
                        <Canvas x:Name="MainCanvas"/>
                    </Border>
                    <TextBlock Grid.Row="1" x:Name="StatsText" Foreground="#B3B3B3" FontSize="20" Margin="0,30,0,0" TextWrapping="Wrap"/>
                </Grid>

                <!-- 5. СПРАВКА -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabInfo, Converter={StaticResource BoolToVis}}">
                    <Border Background="#181818" CornerRadius="20" Padding="40">
                        <StackPanel>
                            <TextBlock Text="ИНСТРУКЦИЯ" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,0,0,30"/>
                            <TextBlock Text="• Поиск похожих: Нажмите 🔍, чтобы найти треки того же жанра и года выпуска." Foreground="#B0B0B0" FontSize="18" Margin="0,10"/>
                            <TextBlock Text="• Плейлист: Нажмите ❤, чтобы сохранить трек. Он будет выделен цветом." Foreground="#B0B0B0" FontSize="18" Margin="0,10"/>
                            <TextBlock Text="• Рекомендации: Вкладка генерирует музыку на основе Графа и формулы Жаккара." Foreground="#B0B0B0" FontSize="18" Margin="0,10"/>
                            <TextBlock Text="• Аналитика: Графики строятся автоматически при переходе в раздел." Foreground="#B0B0B0" FontSize="18" Margin="0,10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <StatusBar Grid.Column="1" VerticalAlignment="Bottom" Background="Transparent" Margin="40,0,40,15">
            <TextBlock x:Name="FooterStatus" Foreground="#535353" FontSize="12"/>
        </StatusBar>
    </Grid>
</Window>